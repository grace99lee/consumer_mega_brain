# Reddit (PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ConsumerInsights/1.0

# YouTube Data API v3
YOUTUBE_API_KEY=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: proxy for scrapers
PROXY_URL=

# ScraperAPI key — required for Amazon scraping on cloud deployments
# Free tier: 1,000 requests/month — https://scraperapi.com
SCRAPERAPI_KEY=

# Defaults
DEFAULT_AI_PROVIDER=claude
DEFAULT_MAX_REVIEWS=500
DEFAULT_BATCH_SIZE=50

# Server
OUTPUT_DIR=output
HOST=127.0.0.1
PORT=8000
